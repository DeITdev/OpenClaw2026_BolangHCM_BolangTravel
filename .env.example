TELEGRAM_BOT_TOKEN=

# GitHub personal access token (classic or fine-grained, with Copilot access).
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub Models endpoint — do not change unless GitHub updates the URL.
GITHUB_MODELS_BASE_URL=

# Model name. Must match a model available in GitHub Models / Copilot.
# Full list: https://github.com/marketplace/models
GITHUB_MODEL_NAME=

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=20000
GOOGLE_MAPS_LOCALE=id
GOOGLE_MAPS_HL=id

FUEL_PRICE_PERTALITE=10000
FUEL_PRICE_PERTAMAX=12500
FUEL_PRICE_SOLAR=6800
DEFAULT_FUEL_CONSUMPTION_KM_PER_LITER=12

LOG_LEVEL=INFO
